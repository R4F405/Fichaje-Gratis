---
import { Image } from 'astro:assets';

// Importar logos
import logoBajocoste from '/public/Images/logo-bajocoste.png';
import logoCaritas from '/public/Images/logo-caritas.png';
import logoRograsa from '/public/Images/logo-rograsa.png';
import logoTacefri from '/public/Images/logo-tacefri.png';
import logoUtielfon from '/public/Images/logo-utielfon.png';
import logoA2 from '/public/Images/logo-a2.png';

// Componente de prueba social: Logos de empresas colaboradoras
---

<section class="py-16 border-b border-brand-light/30 bg-white">
  <div class="container mx-auto px-6 text-center">
    
    <p class="text-sm font-semibold text-brand-dark/80 tracking-wider uppercase mb-12">
      Empresas que confían en nosotros
    </p>
    
    <div class="flex flex-wrap justify-center items-center gap-12 md:gap-16 lg:gap-20">
      
      <!-- Bajocoste Energías -->
      <div class="flex items-center justify-center h-20">
        <Image 
          src={logoBajocoste} 
          alt="Bajocoste Energías" 
          width={128}
          height={128}
          class="h-16 object-contain grayscale opacity-70 hover:grayscale-0 hover:opacity-100 transition-all duration-300"
        />
      </div>
      
      <!-- Cáritas -->
      <div class="flex items-center justify-center h-20">
        <Image 
          src={logoCaritas} 
          alt="Cáritas" 
          width={128}
          height={128}
          class="h-16 object-contain grayscale opacity-70 hover:grayscale-0 hover:opacity-100 transition-all duration-300"
        />
      </div>
      
      <!-- ROGRASA -->
      <div class="flex items-center justify-center h-20">
        <Image 
          src={logoRograsa} 
          alt="ROGRASA" 
          width={128}
          height={128}
          class="h-16 object-contain grayscale opacity-70 hover:grayscale-0 hover:opacity-100 transition-all duration-300"
        />
      </div>
      
      <!-- Tecefri -->
      <div class="flex items-center justify-center h-20">
        <Image 
          src={logoTacefri} 
          alt="Tecefri" 
          width={128}
          height={128}
          class="h-16 object-contain grayscale opacity-70 hover:grayscale-0 hover:opacity-100 transition-all duration-300"
        />
      </div>
      
      <!-- UTILFON -->
      <div class="flex items-center justify-center h-20">
        <Image 
          src={logoUtielfon} 
          alt="UTILFON" 
          width={128}
          height={128}
          class="h-16 object-contain grayscale opacity-70 hover:grayscale-0 hover:opacity-100 transition-all duration-300"
        />
      </div>
      
      <!-- Segundo row en pantallas grandes -->
      <div class="flex items-center justify-center h-20 w-full hidden lg:flex lg:w-auto">
        <Image 
          src={logoA2} 
          alt="Partner" 
          width={128}
          height={128}
          class="h-16 object-contain grayscale opacity-70 hover:grayscale-0 hover:opacity-100 transition-all duration-300"
        />
      </div>

    </div>
  </div>
</section>