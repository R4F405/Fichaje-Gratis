---
// Componente de prueba social: Logos de empresas
// Usamos iconos SVG como ejemplo, luego podrás cambiarlos por las imágenes reales (.png o .svg) de tus clientes.
---

<section class="py-12 border-b border-brand-light/30 bg-white">
  <div class="container mx-auto px-6 text-center">
    
    <p class="text-sm font-semibold text-brand-dark/50 tracking-wider uppercase mb-8">
      Empresas que ya confían en Rapidgest
    </p>
    
    <div class="flex flex-wrap justify-center items-center gap-10 md:gap-20 opacity-50 grayscale hover:grayscale-0 transition-all duration-500">
      
      <div class="flex items-center gap-2">
        <svg class="w-8 h-8 text-brand-dark" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/></svg>
        <span class="text-xl font-bold text-brand-dark">Acme Corp</span>
      </div>
      
      <div class="flex items-center gap-2">
        <svg class="w-8 h-8 text-brand-dark" fill="currentColor" viewBox="0 0 24 24"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
        <span class="text-xl font-bold text-brand-dark">GlobalTech</span>
      </div>
      
      <div class="flex items-center gap-2">
        <svg class="w-8 h-8 text-brand-dark" fill="currentColor" viewBox="0 0 24 24"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/></svg>
        <span class="text-xl font-bold text-brand-dark">Innovate</span>
      </div>
      
      <div class="flex items-center gap-2">
        <svg class="w-8 h-8 text-brand-dark" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2L2 12h3v8h6v-6h2v6h6v-8h3L12 2z"/></svg>
        <span class="text-xl font-bold text-brand-dark">BuildIt</span>
      </div>
      
      <div class="flex items-center gap-2 hidden md:flex">
        <svg class="w-8 h-8 text-brand-dark" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2a10 10 0 1 0 10 10A10 10 0 0 0 12 2zm0 18a8 8 0 1 1 8-8 8 8 0 0 1-8 8z"/></svg>
        <span class="text-xl font-bold text-brand-dark">Studio</span>
      </div>

    </div>
  </div>
</section>