<script>
  // === Elementos ===
  const fichajeInitial = document.getElementById("fichaje-initial");
  const fichajeWorking = document.getElementById("fichaje-working");
  const fichajePaused = document.getElementById("fichaje-paused");
  const avatarInitial = document.getElementById("topbar-avatar-initial");
  const modalOverlay = document.getElementById("modal-overlay");
  const formHora = document.getElementById("form-hora") as HTMLInputElement;
  const formFecha = document.getElementById("form-fecha") as HTMLInputElement;

  const btnPlay = document.getElementById("btn-play");
  const btnQuick = document.getElementById("btn-quick");
  const btnChange = document.getElementById("btn-change");
  const btnBreak = document.getElementById("btn-break");
  const btnStop = document.getElementById("btn-stop");
  const btnResume = document.getElementById("btn-resume");
  const btnStop2 = document.getElementById("btn-stop2");
  const modalCancel = document.getElementById("modal-cancel");
  const modalSave = document.getElementById("modal-save");

  const stopwatchEl = document.getElementById("stopwatch");
  const stopwatchPausedEl = document.getElementById("stopwatch-paused");

  let timer: ReturnType<typeof setInterval> | null = null;
  let elapsed = 0; // seconds

  function formatTime(sec: number): string {
    const h = Math.floor(sec / 3600);
    const m = Math.floor((sec % 3600) / 60);
    const s = sec % 60;
    return `${String(h).padStart(2, "0")}:${String(m).padStart(2, "0")}:${String(s).padStart(2, "0")}`;
  }

  function startTimer() {
    if (timer) clearInterval(timer);
    timer = setInterval(() => {
      elapsed++;
      if (stopwatchEl) stopwatchEl.textContent = formatTime(elapsed);
      if (stopwatchPausedEl)
        stopwatchPausedEl.textContent = formatTime(elapsed);
    }, 1000);
  }

  function stopTimerInterval() {
    if (timer) {
      clearInterval(timer);
      timer = null;
    }
  }

  // State transitions
  function showState(state: "initial" | "working" | "paused") {
    fichajeInitial!.style.display = state === "initial" ? "flex" : "none";
    fichajeWorking!.style.display = state === "working" ? "flex" : "none";
    fichajePaused!.style.display = state === "paused" ? "flex" : "none";
    avatarInitial!.style.display = state === "initial" ? "flex" : "none";
  }

  function openModal() {
    const now = new Date();
    if (formHora)
      formHora.value = now.toLocaleTimeString("es-ES", {
        hour: "2-digit",
        minute: "2-digit",
      });
    if (formFecha)
      formFecha.value = now.toLocaleDateString("es-ES", {
        day: "2-digit",
        month: "2-digit",
        year: "numeric",
      });
    modalOverlay!.style.display = "flex";
  }

  function closeModal() {
    modalOverlay!.style.display = "none";
  }

  function beginWorking() {
    showState("working");
    startTimer();
  }

  function resetAll() {
    stopTimerInterval();
    elapsed = 0;
    if (stopwatchEl) stopwatchEl.textContent = formatTime(0);
    if (stopwatchPausedEl) stopwatchPausedEl.textContent = formatTime(0);
    showState("initial");
    closeModal();
  }

  // "Entrar" -> abre modal
  btnPlay?.addEventListener("click", () => openModal());

  // "Reanudar" (quick start) -> directamente empieza a trabajar
  btnQuick?.addEventListener("click", () => beginWorking());

  // Modal: Cancelar
  modalCancel?.addEventListener("click", () => closeModal());

  // Modal: Guardar -> cierra modal y empieza a trabajar
  modalSave?.addEventListener("click", () => {
    closeModal();
    beginWorking();
  });

  // Cambiar (botón verde) -> reabre modal para cambiar info
  btnChange?.addEventListener("click", () => openModal());

  // Descanso (botón amarillo) -> pausa el timer
  btnBreak?.addEventListener("click", () => {
    stopTimerInterval();
    showState("paused");
  });

  // Stop (botón rojo, working) -> para todo
  btnStop?.addEventListener("click", () => resetAll());

  // Resume (botón en paused) -> reanuda
  btnResume?.addEventListener("click", () => {
    showState("working");
    startTimer();
  });

  // Stop (botón rojo, paused) -> para todo
  btnStop2?.addEventListener("click", () => resetAll());

  // Clic en overlay cierra el modal
  modalOverlay?.addEventListener("click", (e) => {
    if (e.target === modalOverlay) closeModal();
  });
</script>
