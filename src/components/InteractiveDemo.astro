---
// src/components/InteractiveDemo.astro
// Simulación de dashboard tipo Rapidgest con sidebar, gráficos y fichaje interactivo
---

<div class="demo-dashboard">
  <!-- Sidebar -->
  <aside class="demo-sidebar">
    <div class="sidebar-brand">
      <div class="brand-icon">R</div>
      <div class="brand-info">
        <span class="brand-name">Rapidgest</span>
        <span class="brand-role">Demo</span>
      </div>
    </div>

    <nav class="sidebar-nav">
      <span class="nav-item active" role="button">
        <svg
          width="16"
          height="16"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
          ><path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-4 0h4"
          ></path></svg
        >
        Panel de Control
      </span>
      <span class="nav-item" role="button">
        <svg
          width="16"
          height="16"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
          ><path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"
          ></path></svg
        >
        Clientes
      </span>

      <div class="nav-group">
        <span class="nav-group-label" role="button">
          <svg
            width="14"
            height="14"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
            ><path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg
          >
          Horarios
          <svg
            class="chevron"
            width="12"
            height="12"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
            ><path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M19 9l-7 7-7-7"></path></svg
          >
        </span>
        <div class="nav-subgroup">
          <span class="nav-item sub active" role="button">
            <span class="sub-dot"></span>
            Panel de Horarios
          </span>
          <span class="nav-item sub" role="button">
            <span class="sub-dot"></span>
            Hojas de Horas
          </span>
          <span class="nav-item sub" role="button">
            <span class="sub-dot"></span>
            Proyectos
          </span>
          <span class="nav-item sub" role="button">
            <span class="sub-dot"></span>
            Actividades
          </span>
        </div>
      </div>

      <span class="nav-item" role="button">
        <svg
          width="16"
          height="16"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
          ><path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"
          ></path></svg
        >
        Informes
      </span>
      <span class="nav-item" role="button">
        <svg
          width="16"
          height="16"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
          ><path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"
          ></path><path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path></svg
        >
        Configuración
      </span>
    </nav>
  </aside>

  <!-- Main Content -->
  <main class="demo-main">
    <!-- Top Bar -->
    <header class="demo-topbar">
      <div class="topbar-left">
        <h1 class="topbar-title">Panel de Horarios</h1>
        <span class="topbar-breadcrumb"
          >Inicio › Horarios › Panel de Horarios</span
        >
      </div>
      <div class="topbar-right">
        <!-- STATE: Initial - Show Entrar + Reanudar -->
        <div class="fichaje-topbar" id="fichaje-initial">
          <button
            id="btn-play"
            class="btn-top btn-play"
            title="Entrar con detalles"
          >
            <svg width="16" height="16" fill="currentColor" viewBox="0 0 20 20"
              ><path
                fill-rule="evenodd"
                d="M10 18a8 8 0 100-16 8 8 0 000 16zM9.555 7.168A1 1 0 008 8v4a1 1 0 001.555.832l3-2a1 1 0 000-1.664l-3-2z"
                clip-rule="evenodd"></path></svg
            >
            Entrar
          </button>
          <button
            id="btn-quick"
            class="btn-top btn-quick"
            title="Reanudar fichaje rápido"
          >
            <svg
              width="16"
              height="16"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
              ><path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"
              ></path></svg
            >
            Reanudar
          </button>
        </div>

        <!-- STATE: Working - Timer + action buttons -->
        <div
          class="fichaje-topbar fichaje-active"
          id="fichaje-working"
          style="display:none;"
        >
          <div class="timer-display" id="stopwatch">00:00:00</div>
          <button
            id="btn-change"
            class="btn-circle btn-change"
            title="Cambiar cliente/proyecto"
          >
            <svg
              width="16"
              height="16"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
              ><path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"
              ></path></svg
            >
          </button>
          <button id="btn-break" class="btn-circle btn-break" title="Descanso">
            <svg width="16" height="16" fill="currentColor" viewBox="0 0 20 20"
              ><path
                d="M2 4.5A2.5 2.5 0 014.5 2h11A2.5 2.5 0 0118 4.5v1.757a4.5 4.5 0 01-3.12 4.29A3.501 3.501 0 0111.5 14H9v1.5a.5.5 0 01-.5.5h-3a.5.5 0 01-.5-.5V14H4.5A2.5 2.5 0 012 11.5v-7zm3 7a.5.5 0 00.5.5H8v-1.5A1.5 1.5 0 019.5 9h2a1.5 1.5 0 011.415 1h.585a2.5 2.5 0 002.5-2.5V4.5a.5.5 0 00-.5-.5h-11a.5.5 0 00-.5.5v7z"
              ></path></svg
            >
          </button>
          <button
            id="btn-stop"
            class="btn-circle btn-stop"
            title="Salir / Finalizar"
          >
            <svg width="16" height="16" fill="currentColor" viewBox="0 0 20 20"
              ><path
                fill-rule="evenodd"
                d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z"
                clip-rule="evenodd"></path></svg
            >
          </button>
          <div class="topbar-avatar-sm">CM</div>
        </div>

        <!-- STATE: Paused - Timer + Resume + Stop -->
        <div
          class="fichaje-topbar fichaje-active"
          id="fichaje-paused"
          style="display:none;"
        >
          <div class="timer-display paused" id="stopwatch-paused">00:00:00</div>
          <span class="pause-label">En pausa</span>
          <button id="btn-resume" class="btn-top btn-play" title="Reanudar">
            <svg width="16" height="16" fill="currentColor" viewBox="0 0 20 20"
              ><path
                fill-rule="evenodd"
                d="M10 18a8 8 0 100-16 8 8 0 000 16zM9.555 7.168A1 1 0 008 8v4a1 1 0 001.555.832l3-2a1 1 0 000-1.664l-3-2z"
                clip-rule="evenodd"></path></svg
            >
            Reanudar
          </button>
          <button
            id="btn-stop2"
            class="btn-circle btn-stop"
            title="Salir / Finalizar"
          >
            <svg width="16" height="16" fill="currentColor" viewBox="0 0 20 20"
              ><path
                fill-rule="evenodd"
                d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z"
                clip-rule="evenodd"></path></svg
            >
          </button>
        </div>

        <div class="topbar-avatar" id="topbar-avatar-initial">CM</div>
      </div>
    </header>

    <!-- Modal: Confirmar Entrada -->
    <div class="modal-overlay" id="modal-overlay" style="display:none;">
      <div class="modal-card">
        <h2 class="modal-title">Confirmar Entrada</h2>
        <div class="modal-form">
          <div class="form-row two-cols">
            <div class="form-group">
              <label class="form-label"
                >Hora <span class="required">*</span></label
              >
              <input type="text" class="form-input" id="form-hora" readonly />
            </div>
            <div class="form-group">
              <label class="form-label"
                >Fecha <span class="required">*</span></label
              >
              <input type="text" class="form-input" id="form-fecha" readonly />
            </div>
          </div>
          <div class="form-group">
            <label class="form-label">Cliente</label>
            <select class="form-input form-select-native">
              <option value="" disabled selected>Cliente</option>
              <option>Grupo Nevara S.L.</option>
              <option>Textiles del Mediterráneo</option>
              <option>AutoParts Ibérica</option>
              <option>Farmacia Central Plus</option>
              <option>Hotel Marina Bay</option>
              <option>Logística Express 24h</option>
            </select>
          </div>
          <div class="form-row two-cols">
            <div class="form-group">
              <label class="form-label">Proyecto</label>
              <select class="form-input form-select-native">
                <option value="" disabled selected>Proyecto</option>
                <option>App Delivery</option>
                <option>Portal de Reservas</option>
                <option>ERP Logístico</option>
                <option>Tienda Online</option>
                <option>Panel Analíticas</option>
              </select>
            </div>
            <div class="form-group">
              <label class="form-label">Actividad</label>
              <select class="form-input form-select-native">
                <option value="" disabled selected>Actividad</option>
                <option>Diseño UX</option>
                <option>Programación</option>
                <option>Testing QA</option>
                <option>Soporte Técnico</option>
                <option>Documentación</option>
              </select>
            </div>
          </div>
          <div class="form-group">
            <label class="form-label">Localización</label>
            <select class="form-input form-select-native">
              <option value="" disabled selected>Localización</option>
              <option>Oficina Central</option>
              <option>Teletrabajo</option>
              <option>Sede Norte</option>
              <option>Cliente externo</option>
              <option>Coworking Hub</option>
            </select>
          </div>
          <div class="form-group">
            <label class="form-label">Nota</label>
            <textarea class="form-textarea" placeholder="Nota" rows="3"
            ></textarea>
          </div>
        </div>
        <div class="modal-actions">
          <button id="modal-cancel" class="btn-modal btn-cancel"
            >Cancelar</button
          >
          <button id="modal-save" class="btn-modal btn-save">Guardar</button>
        </div>
      </div>
    </div>

    <!-- Content Area -->
    <div class="demo-content">
      <!-- Grid: Chart + Who's In/Out -->
      <div class="dashboard-grid">
        <!-- Bar Chart Card -->
        <div class="chart-card chart-card-wide">
          <div class="chart-card-header">
            <h3 class="chart-card-title">Horas Registradas</h3>
            <button class="chart-btn">Ir a Hojas de Horas</button>
          </div>
          <div class="chart-legend">
            <span class="legend-item"
              ><span class="legend-dot" style="background:#109a9d"></span>Horas
              Trabajadas <strong>454h 0m</strong></span
            >
            <span class="legend-item"
              ><span class="legend-dot" style="background:#f59e0b"
              ></span>Descansos <strong>12h 41m</strong></span
            >
            <span class="legend-item"
              ><span class="legend-dot" style="background:#ef4444"></span>Horas
              Extras <strong>47h 36m</strong></span
            >
          </div>
          <div class="bar-chart-container">
            <svg
              class="bar-chart"
              viewBox="0 0 520 140"
              preserveAspectRatio="xMidYMid meet"
            >
              <text x="2" y="14" class="chart-label">50h</text>
              <text x="2" y="44" class="chart-label">35h</text>
              <text x="2" y="74" class="chart-label">20h</text>
              <text x="2" y="104" class="chart-label">5h</text>
              <text x="2" y="134" class="chart-label">0h</text>
              <line x1="30" y1="10" x2="515" y2="10" class="grid-line"></line>
              <line x1="30" y1="40" x2="515" y2="40" class="grid-line"></line>
              <line x1="30" y1="70" x2="515" y2="70" class="grid-line"></line>
              <line x1="30" y1="100" x2="515" y2="100" class="grid-line"></line>
              <line x1="30" y1="130" x2="515" y2="130" class="grid-line"></line>
              <!-- Ene -->
              <rect x="38" y="40" width="10" height="90" rx="2" fill="#109a9d"
              ></rect>
              <rect x="50" y="95" width="10" height="35" rx="2" fill="#f59e0b"
              ></rect>
              <rect x="62" y="110" width="10" height="20" rx="2" fill="#ef4444"
              ></rect>
              <text x="52" y="140" class="chart-label-x">E</text>
              <!-- Feb -->
              <rect x="80" y="25" width="10" height="105" rx="2" fill="#109a9d"
              ></rect>
              <rect x="92" y="90" width="10" height="40" rx="2" fill="#f59e0b"
              ></rect>
              <rect x="104" y="100" width="10" height="30" rx="2" fill="#ef4444"
              ></rect>
              <text x="94" y="140" class="chart-label-x">F</text>
              <!-- Mar -->
              <rect x="122" y="15" width="10" height="115" rx="2" fill="#109a9d"
              ></rect>
              <rect x="134" y="85" width="10" height="45" rx="2" fill="#f59e0b"
              ></rect>
              <rect x="146" y="95" width="10" height="35" rx="2" fill="#ef4444"
              ></rect>
              <text x="136" y="140" class="chart-label-x">M</text>
              <!-- Abr -->
              <rect x="164" y="35" width="10" height="95" rx="2" fill="#109a9d"
              ></rect>
              <rect x="176" y="100" width="10" height="30" rx="2" fill="#f59e0b"
              ></rect>
              <text x="172" y="140" class="chart-label-x">A</text>
              <!-- May -->
              <rect x="206" y="20" width="10" height="110" rx="2" fill="#109a9d"
              ></rect>
              <rect x="218" y="80" width="10" height="50" rx="2" fill="#f59e0b"
              ></rect>
              <rect x="230" y="90" width="10" height="40" rx="2" fill="#ef4444"
              ></rect>
              <text x="220" y="140" class="chart-label-x">M</text>
              <!-- Jun -->
              <rect x="248" y="30" width="10" height="100" rx="2" fill="#109a9d"
              ></rect>
              <rect x="260" y="92" width="10" height="38" rx="2" fill="#f59e0b"
              ></rect>
              <rect x="272" y="105" width="10" height="25" rx="2" fill="#ef4444"
              ></rect>
              <text x="262" y="140" class="chart-label-x">J</text>
              <!-- Jul -->
              <rect x="290" y="22" width="10" height="108" rx="2" fill="#109a9d"
              ></rect>
              <rect x="302" y="88" width="10" height="42" rx="2" fill="#f59e0b"
              ></rect>
              <rect x="314" y="98" width="10" height="32" rx="2" fill="#ef4444"
              ></rect>
              <text x="304" y="140" class="chart-label-x">J</text>
              <!-- Ago -->
              <rect x="332" y="50" width="10" height="80" rx="2" fill="#109a9d"
              ></rect>
              <rect x="344" y="100" width="10" height="30" rx="2" fill="#f59e0b"
              ></rect>
              <text x="340" y="140" class="chart-label-x">A</text>
              <!-- Sep -->
              <rect x="374" y="28" width="10" height="102" rx="2" fill="#109a9d"
              ></rect>
              <rect x="386" y="85" width="10" height="45" rx="2" fill="#f59e0b"
              ></rect>
              <rect x="398" y="100" width="10" height="30" rx="2" fill="#ef4444"
              ></rect>
              <text x="388" y="140" class="chart-label-x">S</text>
              <!-- Oct -->
              <rect x="416" y="18" width="10" height="112" rx="2" fill="#109a9d"
              ></rect>
              <rect x="428" y="82" width="10" height="48" rx="2" fill="#f59e0b"
              ></rect>
              <rect x="440" y="95" width="10" height="35" rx="2" fill="#ef4444"
              ></rect>
              <text x="430" y="140" class="chart-label-x">O</text>
              <!-- Nov -->
              <rect x="458" y="32" width="10" height="98" rx="2" fill="#109a9d"
              ></rect>
              <rect x="470" y="90" width="10" height="40" rx="2" fill="#f59e0b"
              ></rect>
              <text x="466" y="140" class="chart-label-x">N</text>
              <!-- Dic -->
              <rect x="494" y="45" width="10" height="85" rx="2" fill="#109a9d"
              ></rect>
              <rect x="506" y="105" width="10" height="25" rx="2" fill="#f59e0b"
              ></rect>
              <text x="502" y="140" class="chart-label-x">D</text>
            </svg>
          </div>
        </div>

        <!-- Who's In/Out Card -->
        <div class="chart-card whois-card">
          <h3 class="chart-card-title">¿Quién está dentro/fuera?</h3>
          <p class="whois-subtitle">10 miembros</p>
          <div class="whois-stats">
            <div class="whois-stat">
              <span class="whois-number green">3</span>
              <span class="whois-label">DENTRO</span>
            </div>
            <div class="whois-stat">
              <span class="whois-number amber">2</span>
              <span class="whois-label">DESCANSO</span>
            </div>
            <div class="whois-stat">
              <span class="whois-number slate">5</span>
              <span class="whois-label">FUERA</span>
            </div>
          </div>
          <div class="whois-bar">
            <div class="whois-bar-seg green" style="width:30%"></div>
            <div class="whois-bar-seg amber" style="width:20%"></div>
            <div class="whois-bar-seg slate" style="width:50%"></div>
          </div>
        </div>
      </div>

      <!-- Donut Charts Row -->
      <div class="dashboard-grid donuts-row">
        <div class="chart-card">
          <div class="chart-card-header">
            <h3 class="chart-card-title">Actividades</h3>
            <button class="chart-btn">Ir a Actividades</button>
          </div>
          <div class="donut-wrapper">
            <svg viewBox="0 0 120 120" class="donut-chart">
              <circle
                cx="60"
                cy="60"
                r="46"
                fill="none"
                stroke="#e2e8f0"
                stroke-width="18"></circle>
              <circle
                cx="60"
                cy="60"
                r="46"
                fill="none"
                stroke="#109a9d"
                stroke-width="18"
                stroke-dasharray="115 174"
                stroke-dashoffset="0"
                class="donut-seg"></circle>
              <circle
                cx="60"
                cy="60"
                r="46"
                fill="none"
                stroke="#0e8588"
                stroke-width="18"
                stroke-dasharray="58 231"
                stroke-dashoffset="-115"
                class="donut-seg"></circle>
              <circle
                cx="60"
                cy="60"
                r="46"
                fill="none"
                stroke="#f59e0b"
                stroke-width="18"
                stroke-dasharray="46 243"
                stroke-dashoffset="-173"
                class="donut-seg"></circle>
              <circle
                cx="60"
                cy="60"
                r="46"
                fill="none"
                stroke="#ef4444"
                stroke-width="18"
                stroke-dasharray="29 260"
                stroke-dashoffset="-219"
                class="donut-seg"></circle>
              <circle
                cx="60"
                cy="60"
                r="46"
                fill="none"
                stroke="#8b5cf6"
                stroke-width="18"
                stroke-dasharray="20 269"
                stroke-dashoffset="-248"
                class="donut-seg"></circle>
            </svg>
            <div class="donut-legend">
              <span
                ><span class="legend-dot" style="background:#109a9d"
                ></span>Diseño UX</span
              >
              <span
                ><span class="legend-dot" style="background:#0e8588"
                ></span>Programación</span
              >
              <span
                ><span class="legend-dot" style="background:#f59e0b"
                ></span>Testing QA</span
              >
              <span
                ><span class="legend-dot" style="background:#ef4444"
                ></span>Soporte Técnico</span
              >
              <span
                ><span class="legend-dot" style="background:#8b5cf6"
                ></span>Documentación</span
              >
            </div>
          </div>
        </div>
