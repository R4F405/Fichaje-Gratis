---
// Componente de Scroll Dinámico (Sticky Scroll)
const steps = [
  {
    title: "1. Crea tu espacio de trabajo",
    description: "Configura Rapidgest en minutos. Añade a tus empleados, define los horarios de cada departamento y establece las reglas de fichaje personalizadas para tu empresa.",
    imageColor: "from-blue-100 to-blue-200", // Simula diferentes imágenes/pantallas
    icon: "M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"
  },
  {
    title: "2. Fichaje en tiempo real",
    description: "Tus empleados registran su entrada, pausas y salida desde la app móvil o el ordenador. Con opción de geolocalización para saber exactamente desde dónde fichan.",
    imageColor: "from-brand-green/20 to-brand-green/40",
    icon: "M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"
  },
  {
    title: "3. Informes y control total",
    description: "Olvídate del papeleo a final de mes. Visualiza las horas trabajadas, ausencias y horas extra en tiempo real. Exporta los informes oficiales para la Inspección de Trabajo con un clic.",
    imageColor: "from-brand-blue/20 to-brand-blue/40",
    icon: "M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"
  }
];
---

<section class="py-24 bg-slate-50 relative">
  <div class="container mx-auto px-6 max-w-6xl">
    
    <div class="text-center mb-16 md:mb-24">
      <h2 class="text-4xl font-extrabold text-brand-dark mb-4">Un flujo de trabajo diseñado para ti</h2>
      <p class="text-xl text-brand-dark/70 max-w-2xl mx-auto">La forma más moderna e intuitiva de gestionar el tiempo de tu equipo.</p>
    </div>

    <div class="flex flex-col md:flex-row gap-12 relative items-start">
      
      <div class="w-full md:w-1/2 space-y-24 md:space-y-48 pb-24 md:pb-48">
        {steps.map((step, index) => (
          <div class="group">
            <div class="w-12 h-12 rounded-xl bg-brand-blue/10 flex items-center justify-center mb-6 text-brand-blue">
              <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={step.icon}></path>
              </svg>
            </div>
            <h3 class="text-3xl font-bold text-brand-dark mb-4 group-hover:text-brand-blue transition-colors duration-300">
              {step.title}
            </h3>
            <p class="text-lg text-brand-dark/70 leading-relaxed">
              {step.description}
            </p>
            
            <div class={`mt-8 md:hidden w-full aspect-video rounded-2xl bg-gradient-to-br ${step.imageColor} border border-brand-light/50 flex items-center justify-center shadow-lg`}>
              <span class="text-brand-dark/50 font-medium">Captura Paso {index + 1}</span>
            </div>
          </div>
        ))}
      </div>

      <div class="hidden md:block w-full md:w-1/2 sticky top-32 h-[500px]">
        <div class="w-full h-full rounded-3xl bg-white border border-brand-light shadow-2xl overflow-hidden relative group">
          
          <div class="absolute inset-0 bg-slate-50"></div>
          
          <div class="absolute inset-0 flex flex-col p-8 transition-all duration-500">
            <div class="w-full h-8 flex gap-2 mb-6">
              <div class="w-3 h-3 rounded-full bg-red-400"></div>
              <div class="w-3 h-3 rounded-full bg-yellow-400"></div>
              <div class="w-3 h-3 rounded-full bg-green-400"></div>
            </div>
            <div class="flex-1 rounded-xl bg-gradient-to-br from-brand-blue/10 to-brand-green/10 border border-brand-light/30 flex items-center justify-center">
              <p class="text-brand-dark/50 font-semibold text-lg text-center px-4">
                Aquí la imagen cambiará<br/>automáticamente al hacer scroll
              </p>
            </div>
          </div>

        </div>
      </div>

    </div>
  </div>
</section>