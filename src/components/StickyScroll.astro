---
import { Image } from 'astro:assets';

// Importar capturas de pantalla
import imgConfiguracion from '/public/Images/Configuracion horario.png';
import imgFichar from '/public/Images/Fichar.png';
import imgPanel from '/public/Images/Panel horario.png';

// Componente de Scroll Dinámico (Sticky Scroll)
const steps = [
  {
    title: "1. Crea tu espacio de trabajo",
    description: "Configura Rapidgest en minutos. Añade a tus empleados, define los horarios de cada departamento y establece las reglas de fichaje personalizadas para tu empresa.",
    images: [
      {
        src: imgConfiguracion,
        alt: "Configurar horario"
      }
    ],
    icon: "M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"
  },
  {
    title: "2. Fichaje en tiempo real",
    description: "Tus empleados registran su entrada, pausas y salida desde la app móvil o el ordenador. Con opción de geolocalización para saber exactamente desde dónde fichan.",
    images: [
      {
        src: imgFichar,
        alt: "Fichar en tiempo real"
      }
    ],
    icon: "M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"
  },
  {
    title: "3. Informes y control total",
    description: "Olvídate del papeleo a final de mes. Visualiza las horas trabajadas, ausencias y horas extra en tiempo real. Exporta los informes oficiales para la Inspección de Trabajo con un clic.",
    images: [
      {
        src: imgPanel,
        alt: "Panel de horario"
      }
    ],
    icon: "M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"
  }
];
---

<section class="py-24 bg-slate-50 relative overflow-hidden">
  <div class="absolute inset-0 -z-10 bg-[radial-gradient(circle_at_10%_20%,#109a9d1a,transparent_55%),radial-gradient(circle_at_85%_0%,#dfdd1926,transparent_50%)]"></div>
  <div class="container mx-auto px-6 max-w-6xl">
    <div class="text-center mb-16 md:mb-24">
      <h2 class="text-4xl font-extrabold text-brand-dark mb-4">Un flujo de trabajo diseñado para ti</h2>
      <p class="text-xl text-brand-dark/85 max-w-2xl mx-auto">La forma más moderna e intuitiva de gestionar el tiempo de tu equipo.</p>
    </div>

    <div class="space-y-16 md:space-y-24">
      {steps.map((step, index) => (
        <div
          class={`grid items-center gap-10 md:grid-cols-2 ${
            index % 2 === 1 ? "md:[&>.step-media]:order-first" : ""
          }`}
        >
          <div class="step-content">
            <div class="flex items-center gap-4 mb-6">
              <div class="w-12 h-12 rounded-xl bg-brand-blue/10 flex items-center justify-center text-brand-blue">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={step.icon}></path>
                </svg>
              </div>
              <span class="text-sm font-semibold uppercase tracking-[0.25em] text-brand-blue">Paso {index + 1}</span>
            </div>
            <h3 class="text-3xl font-bold text-brand-dark mb-4">
              {step.title}
            </h3>
            <p class="text-lg text-brand-dark/85 leading-relaxed">
              {step.description}
            </p>
          </div>

          <div class="step-media relative">
            <div class="absolute -inset-6 bg-gradient-to-r from-brand-blue/10 to-brand-green/10 blur-2xl opacity-60"></div>

            {step.images.length > 1 ? (
              <div class="relative">
                <div class="relative z-20 aspect-video rounded-3xl overflow-hidden border border-brand-light/50 shadow-2xl bg-white float-slow">
                  <Image
                    src={step.images[0].src}
                    alt={step.images[0].alt}
                    width={1060}
                    height={600}
                    class="w-full h-full object-cover"
                    loading="lazy"
                  />
                </div>
                <div class="mt-4 grid grid-cols-2 gap-4 md:mt-0 md:absolute md:-bottom-6 md:-right-6 md:w-2/3 md:grid-cols-1">
                  <div class="aspect-video rounded-3xl overflow-hidden border border-brand-light/40 shadow-xl bg-white float-fast">
                    <Image
                      src={step.images[1].src}
                      alt={step.images[1].alt}
                      width={1060}
                      height={600}
                      class="w-full h-full object-cover"
                      loading="lazy"
                    />
                  </div>
                </div>
              </div>
            ) : (
              <div class="relative z-10 aspect-video rounded-3xl overflow-hidden border border-brand-light/50 shadow-2xl bg-white float-slow">
                <Image
                  src={step.images[0].src}
                  alt={step.images[0].alt}
                  width={1060}
                  height={600}
                  class="w-full h-full object-cover"
                  loading="lazy"
                />
              </div>
            )}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  @keyframes floatSlow {
    0%,
    100% {
      transform: translateY(0px);
    }
    50% {
      transform: translateY(-10px);
    }
  }

  @keyframes floatFast {
    0%,
    100% {
      transform: translateY(0px);
    }
    50% {
      transform: translateY(8px);
    }
  }

  .float-slow {
    animation: floatSlow 8s ease-in-out infinite;
  }

  .float-fast {
    animation: floatFast 6s ease-in-out infinite;
  }
</style>