---
// Móvil animado "modo vídeo" — inspirado en la demo de PruebaWebRapidgestAnimacion
// (solo la parte de fichaje; nada de facturación). 3 variantes cortas en loop.
const { variant } = Astro.props as { variant: "workspace" | "fichaje" | "informes" };

const subtitles: Record<string, string> = {
  workspace: "Configuración inicial",
  fichaje: "Fichaje · Entrada",
  informes: "Fichajes en curso",
};
const navActive: Record<string, number> = { workspace: 0, fichaje: 1, informes: 2 };
---

<div class="pmk-scene" data-variant={variant} aria-hidden="true">
  <div class="pmk-phone-wrap">
    <div class="pmk-ground"></div>
    <div class="pmk-float">
      <div class="pmk-phone">
        <div class="pmk-island"></div>
        <div class="pmk-screen">
          <div class="pmk-status">
            <span>9:41</span>
            <svg viewBox="0 0 34 10" fill="currentColor"><rect x="0" y="5" width="2.4" height="5" rx=".6"/><rect x="3.6" y="3.4" width="2.4" height="6.6" rx=".6"/><rect x="7.2" y="1.8" width="2.4" height="8.2" rx=".6"/><rect x="10.8" y="0" width="2.4" height="10" rx=".6"/><rect x="18" y=".5" width="12" height="9" rx="2.2" fill="none" stroke="currentColor"/><rect x="19.5" y="2" width="8" height="6" rx="1.1"/><rect x="30.8" y="3.2" width="1.6" height="3.6" rx=".8"/></svg>
          </div>
          <div class="pmk-appbar">
            <div class="pmk-logo">R</div>
            <div><b>Rapidgest</b><small data-role="subtitle">{subtitles[variant]}</small></div>
            <div class="pmk-avatar">GM</div>
          </div>

          <div class="pmk-view">
            {variant === "workspace" && (
              <Fragment>
                <div class="pmk-scr on" data-role="scr-setup">
                  <div class="pmk-form-t">Configura tu empresa</div>
                  <div class="pmk-field">
                    <label>Nombre de la empresa</label>
                    <div class="val ph" data-role="f-company">Nombre</div>
                  </div>
                  <div class="pmk-sect">Empleados añadidos</div>
                  <div class="pmk-emplist">
                    <div class="pmk-emp pmk-pop" data-role="emp-1"><span class="av">AG</span>Ana García</div>
                    <div class="pmk-emp pmk-pop" data-role="emp-2"><span class="av">MT</span>Marc Torres</div>
                    <div class="pmk-emp pmk-pop" data-role="emp-3"><span class="av">LP</span>Laia Puig</div>
                  </div>
                  <div class="pmk-emit" data-role="btn-setup">Crear espacio</div>
                </div>
                <div class="pmk-scr pmk-scr--ok" data-role="scr-done">
                  <div class="pmk-okc"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg></div>
                  <div class="pmk-okt"><b>Espacio de trabajo listo</b><span>Ya puedes empezar a fichar</span></div>
                </div>
                <div class="pmk-scr" data-role="scr-horario">
                  <div class="pmk-form-t">Agregar Horario</div>
                  <div class="pmk-field">
                    <label>Nombre</label>
                    <div class="val ph" data-role="h-name">Nombre</div>
                  </div>
                  <div class="pmk-chiprow">
                    <span class="pmk-chipbtn on">Fijo</span>
                    <span class="pmk-chipbtn">Flexible</span>
                    <span class="pmk-chipbtn">Semanal</span>
                  </div>
                  <div class="pmk-chiprow">
                    <span class="pmk-daychip" data-role="day-lun">Lun</span>
                    <span class="pmk-daychip" data-role="day-mar">Mar</span>
                    <span class="pmk-daychip" data-role="day-mie">Mié</span>
                    <span class="pmk-daychip" data-role="day-jue">Jue</span>
                    <span class="pmk-daychip" data-role="day-vie">Vie</span>
                    <span class="pmk-daychip off">Sáb</span>
                    <span class="pmk-daychip off">Dom</span>
                  </div>
                  <div class="pmk-hrow pmk-pop" data-role="h-row1"><span>Lunes</span><b>09:00 – 17:00</b></div>
                  <div class="pmk-hrow pmk-pop" data-role="h-row2"><span>Martes</span><b>09:00 – 17:00</b></div>
                  <div class="pmk-hnote">Sáb · Dom — Día de descanso</div>
                  <div class="pmk-emit" data-role="btn-horario">Guardar horario</div>
                </div>
              </Fragment>
            )}

            {variant === "fichaje" && (
              <Fragment>
                <div class="pmk-scr on" data-role="scr-fich">
                  <div class="pmk-toast" data-role="toast">
                    <div class="tk"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg></div>
                    <div><b>Entrada registrada · 09:02</b><span>TecnoClima · Instalación SAT</span></div>
                  </div>
                  <div class="pmk-form-t">Confirmar entrada</div>
                  <div class="pmk-frow">
                    <div class="pmk-field"><label>Hora</label><div class="val">09:02</div></div>
                    <div class="pmk-field"><label>Fecha</label><div class="val">09-07-2026</div></div>
                  </div>
                  <div class="pmk-field sel"><label>Cliente</label><div class="val ph" data-role="f-client">Cliente</div></div>
                  <div class="pmk-field sel"><label>Proyecto</label><div class="val ph" data-role="f-project">Proyecto</div></div>
                  <div class="pmk-field sel"><label>Actividad</label><div class="val ph" data-role="f-activity">Actividad</div></div>
                  <div class="pmk-field sel"><label>Localización</label><div class="val ph" data-role="f-location">Localización</div></div>
                  <div class="pmk-emit" data-role="btn">Fichar entrada</div>
                </div>
                <div class="pmk-scr" data-role="scr-pausa">
                  <div class="pmk-toast" data-role="toast-pausa">
                    <div class="tk"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg></div>
                    <div><b>Pausa iniciada · 13:00</b><span>Comida</span></div>
                  </div>
                  <div class="pmk-fich">
                    <div class="fi"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 3"/></svg></div>
                    <div><b>En curso desde las 09:02</b><span>TecnoClima · Instalación SAT</span></div>
                  </div>
                  <div class="pmk-emit" data-role="btn-pausa">Iniciar pausa · Comida</div>
                </div>
              </Fragment>
            )}

            {variant === "informes" && (
              <Fragment>
                <div class="pmk-scr on" data-role="scr-list">
                  <div class="pmk-searchbar">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="7"/><path d="m21 21-4.3-4.3"/></svg>
                    Todos
                  </div>
                  <div class="pmk-fcard pmk-pop" data-role="fc-1">
                    <div class="fc-top"><b>Sara Molina</b><span class="pmk-chip pmk-chip--curso">En curso</span></div>
                    <div class="fc-row"><span>Tipo</span><span class="pmk-chip pmk-chip--tipo">Trabajo</span></div>
                    <div class="fc-row"><span>Periodo</span><span class="fc-time">10-07-2026 · 09:03am</span></div>
                  </div>
                  <div class="pmk-fcard pmk-pop" data-role="fc-2">
                    <div class="fc-top"><b>David Ferrer</b><span class="pmk-chip pmk-chip--curso">En curso</span></div>
                    <div class="fc-row"><span>Tipo</span><span class="pmk-chip pmk-chip--tipo">Trabajo</span></div>
                    <div class="fc-row"><span>Periodo</span><span class="fc-time">10-07-2026 · 08:29am</span></div>
                  </div>
                </div>
                <div class="pmk-scr" data-role="scr-hours">
                  <div class="pmk-kpi pmk-pop" data-role="kpi">
                    <div class="pmk-kpi-label">Horas este mes</div>
                    <div class="pmk-kpi-row">
                      <span class="pmk-kpi-value">305h 1m</span>
                      <span class="pmk-badge-x">+2h 20m extra</span>
                    </div>
                  </div>
                  <div class="pmk-minis pmk-pop" data-role="minis">
                    <div class="pmk-mini"><span>Hoy</span><b>6h 12m</b></div>
                    <div class="pmk-mini"><span>Esta semana</span><b>32h 40m</b></div>
                  </div>
                  <div class="pmk-chartc">
                    <div class="pmk-chart" data-role="chart">
                      <div class="cb"><i class="g" style="--v:62%"></i></div>
                      <div class="cb"><i class="x" style="--v:8%"></i><i class="g" style="--v:84%"></i></div>
                      <div class="cb"><i class="x" style="--v:6%"></i><i class="g" style="--v:76%"></i></div>
                      <div class="cb"><i class="g" style="--v:70%"></i></div>
                      <div class="cb"><i class="g" style="--v:58%"></i></div>
                      <div class="cb"><i class="g" style="--v:12%"></i></div>
                      <div class="cb"><i class="g" style="--v:0%"></i></div>
                    </div>
                    <div class="pmk-chart-l"><span>L</span><span>M</span><span>X</span><span>J</span><span>V</span><span>S</span><span>D</span></div>
                  </div>
                  <div class="pmk-fich pmk-pop" data-role="team">
                    <div class="fi"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H7a4 4 0 0 0-4 4v2"/><circle cx="10" cy="7" r="4"/><path d="M21 21v-2a4 4 0 0 0-3-3.87"/></svg></div>
                    <div>
                      <b>Equipo · 11 trabajadores</b>
                      <div class="pmk-chips">
                        <span class="pmk-chip pmk-chip--in">4 Dentro</span>
                        <span class="pmk-chip pmk-chip--pa">1 Descanso</span>
                        <span class="pmk-chip pmk-chip--out">6 Fuera</span>
                      </div>
                    </div>
                  </div>
                </div>
              </Fragment>
            )}
          </div>

          <div class="pmk-nav">
            <span data-role="nav-0" class:list={[{ on: navActive[variant] === 0 }]}><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/></svg>Ajustes</span>
            <span data-role="nav-1" class:list={[{ on: navActive[variant] === 1 }]}><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 3"/></svg>Fichaje</span>
            <span data-role="nav-2" class:list={[{ on: navActive[variant] === 2 }]}><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 3v18h18"/><path d="M7 15l4-6 4 3 5-8"/></svg>Informes</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  .pmk-scene {
    --pmk-brand: #0d7d80;
    --pmk-brand-dark: #0b6a6d;
    --pmk-brand-bg: #e6f3f3;
    --pmk-navy: #0f172a;
    --pmk-ink: #475569;
    --pmk-muted: #64748b;
    --pmk-success: #16a34a;
    --pmk-success-bg: #dcfce7;
    --pmk-danger: #ef4444;
    --pmk-line: #e2e8f0;
    --pmk-screen-bg: #f8fafc;
    --pmk-phone-w: clamp(210px, 26vw, 250px);
    --pmk-tilt: 0deg;
    position: relative;
    display: flex;
    justify-content: center;
    align-items: center;
    padding: clamp(20px, 3vw, 32px) 0;
    font-family: inherit;
  }
  .pmk-scene::before {
    content: "";
    position: absolute;
    inset: 2% 4%;
    background: radial-gradient(50% 50% at 50% 42%, rgba(13, 125, 128, 0.12), transparent 72%);
    filter: blur(10px);
    border-radius: 50%;
    z-index: 0;
  }
  @keyframes pmkFloat {
    from { transform: translateY(-5px); }
    to { transform: translateY(5px); }
  }
  .pmk-float { animation: pmkFloat 6.5s ease-in-out infinite alternate; will-change: transform; }
  .pmk-phone-wrap { position: relative; z-index: 1; }
  .pmk-phone {
    position: relative;
    width: var(--pmk-phone-w);
    aspect-ratio: 292/596;
    border-radius: calc(var(--pmk-phone-w) * 0.16);
    background: linear-gradient(160deg, #3a3f4b, #1e2129 45%, #14161c);
    padding: calc(var(--pmk-phone-w) * 0.028);
    transform: rotate(var(--pmk-tilt));
    box-shadow:
      0 2px 6px rgba(15, 23, 42, 0.18),
      0 24px 48px -12px rgba(15, 23, 42, 0.3),
      0 60px 90px -30px rgba(15, 23, 42, 0.24),
      inset 0 0 0 1px rgba(255, 255, 255, 0.08);
  }
  .pmk-phone::before, .pmk-phone::after { content: ""; position: absolute; background: #2a2e38; border-radius: 4px; }
  .pmk-phone::before { left: -3px; top: 22%; width: 3px; height: 11%; }
  .pmk-phone::after { right: -3px; top: 26%; width: 3px; height: 8%; }
  .pmk-ground {
    position: absolute; left: 8%; right: 8%; bottom: calc(var(--pmk-phone-w) * -0.1);
    height: calc(var(--pmk-phone-w) * 0.11);
    background: radial-gradient(50% 50% at 50% 50%, rgba(15, 23, 42, 0.16), transparent 70%);
    filter: blur(4px); z-index: -1;
  }
  .pmk-screen {
    position: relative; height: 100%; overflow: hidden;
    border-radius: calc(var(--pmk-phone-w) * 0.135);
    background: var(--pmk-screen-bg);
    display: flex; flex-direction: column;
    font-size: calc(var(--pmk-phone-w) * 0.046);
  }
  .pmk-island {
    position: absolute; top: calc(var(--pmk-phone-w) * 0.035); left: 50%; transform: translateX(-50%);
    width: 30%; height: calc(var(--pmk-phone-w) * 0.062);
    background: #0b0c10; border-radius: 999px; z-index: 30;
  }
  .pmk-status {
    display: flex; justify-content: space-between; align-items: flex-end;
    padding: 0.9em 1.5em 0; height: 2.6em; flex: none;
    font-weight: 600; font-size: 0.8em; color: var(--pmk-navy);
  }
  .pmk-status svg { width: 3.4em; height: 1em; display: block; }
  .pmk-appbar {
    display: flex; align-items: center; gap: 0.55em; flex: none;
    padding: 0.8em 1.1em 0.7em; background: #fff; border-bottom: 1px solid var(--pmk-line);
  }
  .pmk-logo {
    width: 1.9em; height: 1.9em; border-radius: 0.55em; flex: none;
    background: linear-gradient(140deg, var(--pmk-brand), var(--pmk-brand-dark));
    color: #fff; font-weight: 800; font-size: 1em;
    display: flex; align-items: center; justify-content: center;
    box-shadow: 0 2px 6px rgba(13, 125, 128, 0.35);
  }
  .pmk-appbar b { color: var(--pmk-navy); font-size: 1.02em; font-weight: 700; letter-spacing: -0.01em; }
  .pmk-appbar small { display: block; color: var(--pmk-muted); font-size: 0.68em; font-weight: 500; transition: opacity 0.2s; }
  .pmk-avatar {
    margin-left: auto; width: 1.8em; height: 1.8em; border-radius: 50%;
    background: var(--pmk-brand-bg); color: var(--pmk-brand-dark); font-size: 0.9em; font-weight: 700;
    display: flex; align-items: center; justify-content: center;
  }
  .pmk-view { position: relative; flex: 1; overflow: hidden; }
  .pmk-scr {
    position: absolute; inset: 0; padding: 0.9em 1em 0;
    display: flex; flex-direction: column; gap: 0.65em;
    opacity: 0; pointer-events: none; overflow: hidden;
  }
  .pmk-scr.on { opacity: 1; transition: opacity 0.45s ease; }
  .pmk-form-t { font-size: 0.82em; font-weight: 700; color: var(--pmk-navy); }
  .pmk-field {
    background: #fff; border: 1px solid var(--pmk-line); border-radius: 0.75em;
    padding: 0.55em 0.75em;
  }
  .pmk-field label { display: block; font-size: 0.58em; font-weight: 600; color: var(--pmk-muted); margin-bottom: 0.15em; }
  .pmk-field .val { font-size: 0.72em; font-weight: 600; color: var(--pmk-navy); min-height: 1.25em; }
  .pmk-field .val.ph { color: var(--pmk-muted); font-weight: 500; }
  .pmk-field.sel { position: relative; }
  .pmk-field.sel::after {
    content: ""; position: absolute; right: 0.85em; top: 50%;
    width: 0.42em; height: 0.42em;
    border-right: 2px solid var(--pmk-muted); border-bottom: 2px solid var(--pmk-muted);
    transform: translateY(-70%) rotate(45deg);
  }
  @keyframes pmkPop { from { transform: scale(0.94); opacity: 0.2; } to { transform: scale(1); opacity: 1; } }
  .pmk-field .val.set { animation: pmkPop 0.35s cubic-bezier(0.22, 1, 0.36, 1); }
  .pmk-frow { display: flex; gap: 0.6em; }
  .pmk-frow .pmk-field { flex: 1; min-width: 0; }
  .pmk-pop { opacity: 0; transform: translateY(10px) scale(0.98); transition: opacity 0.45s cubic-bezier(0.22, 1, 0.36, 1), transform 0.45s cubic-bezier(0.22, 1, 0.36, 1); }
  .pmk-pop.on { opacity: 1; transform: none; }
  .pmk-emit {
    margin-top: auto; margin-bottom: 1em; flex: none;
    background: var(--pmk-brand); color: #fff; text-align: center;
    border-radius: 0.75em; padding: 0.7em; font-size: 0.72em; font-weight: 700;
    box-shadow: 0 6px 14px -4px rgba(13, 125, 128, 0.55);
    transition: transform 0.18s ease, background 0.18s ease;
  }
  .pmk-emit.press { transform: scale(0.93); background: var(--pmk-brand-dark); }
  .pmk-scr--ok { align-items: center; justify-content: center; text-align: center; gap: 0.7em; }
  .pmk-okc {
    width: 3.4em; height: 3.4em; border-radius: 50%;
    background: var(--pmk-success-bg); color: var(--pmk-success);
    display: flex; align-items: center; justify-content: center;
  }
  .pmk-okc svg { width: 1.8em; height: 1.8em; }
  .pmk-okc svg path { stroke-dasharray: 30; stroke-dashoffset: 30; }
  .pmk-scr.on .pmk-okc svg path { transition: stroke-dashoffset 0.55s ease 0.2s; stroke-dashoffset: 0; }
  .pmk-okt b { display: block; font-size: 0.8em; font-weight: 800; color: var(--pmk-navy); }
  .pmk-okt span { font-size: 0.62em; color: var(--pmk-muted); font-weight: 500; }
  .pmk-sect { font-size: 0.7em; font-weight: 700; color: var(--pmk-navy); padding: 0 0.15em; }
  .pmk-emplist { display: flex; flex-direction: column; gap: 0.4em; }
  .pmk-emp {
    display: flex; align-items: center; gap: 0.5em;
    background: #fff; border: 1px solid var(--pmk-line); border-radius: 0.7em;
    padding: 0.45em 0.7em; font-size: 0.68em; font-weight: 600; color: var(--pmk-navy);
    box-shadow: 0 3px 4px rgba(0, 0, 0, 0.03);
  }
  .pmk-emp .av {
    width: 1.7em; height: 1.7em; border-radius: 50%; flex: none;
    background: var(--pmk-brand-bg); color: var(--pmk-brand-dark);
    font-size: 0.85em; font-weight: 700;
    display: flex; align-items: center; justify-content: center;
  }
  .pmk-chiprow { display: flex; gap: 0.4em; flex-wrap: wrap; }
  .pmk-chipbtn {
    font-size: 0.6em; font-weight: 700; padding: 0.4em 0.75em; border-radius: 0.55em;
    background: #fff; border: 1px solid var(--pmk-line); color: var(--pmk-ink);
  }
  .pmk-chipbtn.on { background: var(--pmk-brand); border-color: var(--pmk-brand); color: #fff; }
  .pmk-daychip {
    flex: 1; text-align: center; font-size: 0.6em; font-weight: 700; padding: 0.4em 0; border-radius: 0.5em;
    background: #fff; border: 1px solid var(--pmk-line); color: var(--pmk-ink);
    transition: background 0.3s, color 0.3s, border-color 0.3s;
  }
  .pmk-daychip.on { background: var(--pmk-brand); border-color: var(--pmk-brand); color: #fff; }
  .pmk-daychip.off { color: var(--pmk-line); border-color: var(--pmk-line); }
  .pmk-hrow {
    background: #fff; border: 1px solid var(--pmk-line); border-radius: 0.75em;
    padding: 0.5em 0.75em; display: flex; justify-content: space-between; align-items: center;
  }
  .pmk-hrow span { font-size: 0.68em; font-weight: 700; color: var(--pmk-navy); }
  .pmk-hrow b { font-size: 0.62em; font-weight: 600; color: var(--pmk-ink); font-variant-numeric: tabular-nums; }
  .pmk-hnote { font-size: 0.6em; color: var(--pmk-muted); font-weight: 500; padding: 0 0.15em; }
  .pmk-kpi {
    background: #fff; border: 1px solid var(--pmk-line); border-radius: 1em;
    padding: 0.95em 1.05em; box-shadow: 0 3px 4px rgba(0, 0, 0, 0.03);
  }
  .pmk-kpi-label { font-size: 0.72em; color: var(--pmk-ink); font-weight: 500; }
  .pmk-kpi-row { display: flex; align-items: center; gap: 0.5em; margin: 0.15em 0 0; }
  .pmk-kpi-value { font-size: 1.5em; font-weight: 700; color: var(--pmk-navy); letter-spacing: -0.02em; font-variant-numeric: tabular-nums; }
  .pmk-badge-x {
    display: inline-flex; align-items: center; gap: 0.25em;
    font-size: 0.62em; font-weight: 700; color: var(--pmk-danger);
    background: #fef2f2; border: 1px solid rgba(239, 68, 68, 0.25);
    padding: 0.2em 0.55em; border-radius: 0.5em;
  }
  .pmk-minis { display: flex; gap: 0.6em; }
  .pmk-mini {
    flex: 1; background: #fff; border: 1px solid var(--pmk-line);
    border-radius: 0.8em; padding: 0.55em 0.75em;
    box-shadow: 0 3px 4px rgba(0, 0, 0, 0.03);
  }
  .pmk-mini span { display: block; font-size: 0.58em; color: var(--pmk-muted); font-weight: 600; }
  .pmk-mini b { font-size: 0.82em; color: var(--pmk-navy); font-weight: 800; font-variant-numeric: tabular-nums; }
  .pmk-chartc {
    background: #fff; border: 1px solid var(--pmk-line); border-radius: 1em;
    padding: 0.8em 0.9em 0.55em; box-shadow: 0 3px 4px rgba(0, 0, 0, 0.03);
  }
  .pmk-chart { display: flex; align-items: flex-end; gap: 0.45em; height: 5.6em; }
  .pmk-chart .cb { flex: 1; height: 100%; display: flex; flex-direction: column; justify-content: flex-end; }
  .pmk-chart .cb i { display: block; width: 100%; height: 0; transition: height 0.7s cubic-bezier(0.22, 1, 0.36, 1); }
  .pmk-chart .cb .x { background: var(--pmk-danger); border-radius: 0.25em 0.25em 0 0; }
  .pmk-chart .cb .g { background: var(--pmk-success); border-radius: 0.25em 0.25em 0 0; }
  .pmk-chart .cb .x + .g { border-radius: 0; }
  .pmk-chart .cb:nth-child(1) i { transition-delay: 0.05s; }
  .pmk-chart .cb:nth-child(2) i { transition-delay: 0.12s; }
  .pmk-chart .cb:nth-child(3) i { transition-delay: 0.19s; }
  .pmk-chart .cb:nth-child(4) i { transition-delay: 0.26s; }
  .pmk-chart .cb:nth-child(5) i { transition-delay: 0.33s; }
  .pmk-chart .cb:nth-child(6) i { transition-delay: 0.4s; }
  .pmk-chart .cb:nth-child(7) i { transition-delay: 0.47s; }
  .pmk-chart.on .cb i { height: var(--v); }
  .pmk-chart-l { display: flex; gap: 0.45em; margin-top: 0.35em; }
  .pmk-chart-l span { flex: 1; text-align: center; font-size: 0.52em; color: var(--pmk-muted); font-weight: 600; }
  .pmk-fich {
    background: #fff; border: 1px solid var(--pmk-line); border-radius: 1em;
    padding: 0.72em 1.05em; display: flex; align-items: center; gap: 0.65em;
    box-shadow: 0 3px 4px rgba(0, 0, 0, 0.03);
  }
  .pmk-fich .fi {
    width: 2em; height: 2em; border-radius: 0.6em; flex: none;
    background: var(--pmk-brand-bg); color: var(--pmk-brand-dark);
    display: flex; align-items: center; justify-content: center;
  }
  .pmk-fich .fi svg { width: 1.1em; height: 1.1em; }
  .pmk-fich b { display: block; font-size: 0.72em; font-weight: 600; color: var(--pmk-navy); }
  .pmk-fich span { font-size: 0.62em; color: var(--pmk-muted); font-weight: 500; }
  .pmk-chips { display: flex; gap: 0.4em; margin-top: 0.3em; }
  .pmk-chip { font-size: 0.56em; font-weight: 700; padding: 0.18em 0.55em; border-radius: 0.45em; }
  .pmk-chip--in { background: var(--pmk-success-bg); color: #04b440; }
  .pmk-chip--pa { background: #fff8dd; color: #dfa000; }
  .pmk-chip--out { background: var(--pmk-line); color: var(--pmk-ink); }
  .pmk-chip--curso { background: #fff8dd; color: #dfa000; }
  .pmk-chip--tipo { background: var(--pmk-brand-bg); color: var(--pmk-brand-dark); }
  .pmk-searchbar {
    display: flex; align-items: center; gap: 0.5em;
    background: #fff; border: 1px solid var(--pmk-line); border-radius: 0.75em;
    padding: 0.55em 0.8em; font-size: 0.68em; font-weight: 600; color: var(--pmk-muted);
  }
  .pmk-searchbar svg { width: 1.1em; height: 1.1em; flex: none; }
  .pmk-fcard {
    background: #fff; border: 1px solid var(--pmk-line); border-radius: 1em;
    padding: 0.7em 0.85em; display: flex; flex-direction: column; gap: 0.4em;
    box-shadow: 0 3px 4px rgba(0, 0, 0, 0.03);
  }
  .fc-top { display: flex; justify-content: space-between; align-items: center; }
  .fc-top b { font-size: 0.74em; font-weight: 700; color: var(--pmk-navy); }
  .fc-row { display: flex; justify-content: space-between; align-items: center; }
  .fc-row > span:first-child { font-size: 0.6em; color: var(--pmk-muted); font-weight: 500; }
  .fc-time { font-size: 0.62em; font-weight: 700; color: var(--pmk-navy); font-variant-numeric: tabular-nums; }
  .pmk-toast {
    position: absolute; left: 0.8em; right: 0.8em; top: 0.55em; z-index: 6;
    display: flex; align-items: center; gap: 0.55em;
    background: #fff; border: 1px solid rgba(22, 163, 74, 0.4); border-radius: 0.8em;
    padding: 0.55em 0.8em;
    box-shadow: 0 10px 24px -8px rgba(15, 23, 42, 0.28);
    transform: translateY(-140%); opacity: 0;
    transition: transform 0.55s cubic-bezier(0.22, 1, 0.36, 1), opacity 0.4s ease;
  }
  .pmk-toast.on { transform: none; opacity: 1; }
  .pmk-toast .tk {
    width: 1.5em; height: 1.5em; border-radius: 50%; flex: none;
    background: var(--pmk-success-bg); color: var(--pmk-success);
    display: flex; align-items: center; justify-content: center;
  }
  .pmk-toast .tk svg { width: 0.85em; height: 0.85em; }
  .pmk-toast b { display: block; font-size: 0.64em; font-weight: 700; color: var(--pmk-navy); }
  .pmk-toast span { display: block; font-size: 0.56em; color: var(--pmk-muted); font-weight: 500; }
  .pmk-nav {
    display: flex; background: #fff; border-top: 1px solid var(--pmk-line); flex: none;
    padding: 0.55em 0.4em calc(0.55em + var(--pmk-phone-w) * 0.02);
  }
  .pmk-nav span {
    flex: 1; display: flex; flex-direction: column; align-items: center; gap: 0.22em;
    font-size: 0.58em; font-weight: 600; color: var(--pmk-muted); transition: color 0.3s;
  }
  .pmk-nav svg { width: 1.7em; height: 1.7em; }
  .pmk-nav .on { color: var(--pmk-brand-dark); }

  @media (max-width: 1024px) {
    .pmk-scene { --pmk-phone-w: clamp(200px, 42vw, 240px); }
  }
  @media (prefers-reduced-motion: reduce) {
    .pmk-float { animation: none !important; }
  }
</style>

<script>
  function initScene(scene: Element) {
    const variant = scene.getAttribute("data-variant");
    const $ = (role: string) => scene.querySelector(`[data-role="${role}"]`) as HTMLElement | null;
    const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    let timers: number[] = [];
    let running = false;

    function later(fn: () => void, ms: number) {
      timers.push(window.setTimeout(fn, ms));
    }
    function clearTimers() {
      timers.forEach((t) => clearTimeout(t));
      timers = [];
    }
    function fill(role: string, html: string) {
      const el = $(role);
      if (!el) return;
      el.innerHTML = html;
      el.classList.remove("ph", "set");
      void el.offsetWidth;
      el.classList.add("set");
    }
    function press(role: string) {
      const el = $(role);
      if (!el) return;
      el.classList.add("press");
      later(() => el.classList.remove("press"), 260);
    }
    function show(role: string, on: boolean) {
      const el = $(role);
      if (el) el.classList.toggle("on", on);
    }
    function text(role: string, txt: string) {
      const el = $(role);
      if (el) el.textContent = txt;
    }

    let steps: Array<[number, () => void]> = [];
    let loop = 5000;

    if (variant === "workspace") {
      loop = 10800;
      steps = [
        [500, () => fill("f-company", "Mi Empresa S.L.")],
        [1300, () => show("emp-1", true)],
        [1750, () => show("emp-2", true)],
        [2200, () => show("emp-3", true)],
        [3100, () => press("btn-setup")],
        [3450, () => { show("scr-setup", false); show("scr-done", true); }],
        [5200, () => {
          show("scr-done", false); show("scr-horario", true);
          text("subtitle", "Fichaje · Horarios"); show("nav-0", false); show("nav-1", true);
        }],
        [5600, () => fill("h-name", "Horario General")],
        [6300, () => show("day-lun", true)],
        [6550, () => show("day-mar", true)],
        [6800, () => show("day-mie", true)],
        [7050, () => show("day-jue", true)],
        [7300, () => show("day-vie", true)],
        [7800, () => show("h-row1", true)],
        [8100, () => show("h-row2", true)],
        [8900, () => press("btn-horario")],
        [9200, () => {
          show("scr-horario", false); show("scr-setup", true);
          text("subtitle", "Configuración inicial"); show("nav-1", false); show("nav-0", true);
        }],
      ];
    } else if (variant === "fichaje") {
      loop = 7800;
      steps = [
        [400, () => fill("f-client", "TecnoClima Instalaciones S.L.")],
        [1000, () => fill("f-project", "Instalación SAT · Fase 2")],
        [1600, () => fill("f-activity", "Mantenimiento")],
        [2200, () => fill("f-location", 'Valencia · GPS <b style="color:var(--pmk-success)">✓</b>')],
        [3000, () => press("btn")],
        [3300, () => show("toast", true)],
        [4300, () => show("toast", false)],
        [4500, () => { show("scr-fich", false); show("scr-pausa", true); }],
        [5300, () => press("btn-pausa")],
        [5600, () => show("toast-pausa", true)],
        [7000, () => show("toast-pausa", false)],
        [7300, () => { show("scr-pausa", false); show("scr-fich", true); }],
      ];
    } else if (variant === "informes") {
      loop = 6200;
      steps = [
        [300, () => show("fc-1", true)],
        [650, () => show("fc-2", true)],
        [2200, () => { show("scr-list", false); show("scr-hours", true); text("subtitle", "Panel de horarios"); }],
        [2400, () => show("kpi", true)],
        [2700, () => { const c = $("chart"); if (c) c.classList.add("on"); }],
        [3600, () => show("minis", true)],
        [4000, () => show("team", true)],
        [5800, () => { show("scr-hours", false); show("scr-list", true); text("subtitle", "Fichajes en curso"); }],
      ];
    }

    // Ralentiza un poco toda la secuencia para que dé tiempo a leer.
    const SPEED = 1.3;
    steps = steps.map(([t, fn]) => [Math.round(t * SPEED), fn] as [number, () => void]);
    loop = Math.round(loop * SPEED);

    function domReset() {
      clearTimers();
      if (variant === "workspace") {
        const el = $("f-company"); if (el) { el.innerHTML = "Nombre"; el.classList.add("ph"); el.classList.remove("set"); }
        show("emp-1", false); show("emp-2", false); show("emp-3", false);
        const btn = $("btn-setup"); if (btn) btn.classList.remove("press");
        show("scr-done", false);
        show("scr-setup", true);
        show("scr-horario", false);
        const hn = $("h-name"); if (hn) { hn.innerHTML = "Nombre"; hn.classList.add("ph"); hn.classList.remove("set"); }
        ["day-lun", "day-mar", "day-mie", "day-jue", "day-vie"].forEach((r) => show(r, false));
        show("h-row1", false); show("h-row2", false);
        const bh = $("btn-horario"); if (bh) bh.classList.remove("press");
        text("subtitle", "Configuración inicial");
        show("nav-0", true); show("nav-1", false);
      } else if (variant === "fichaje") {
        [["f-client", "Cliente"], ["f-project", "Proyecto"], ["f-activity", "Actividad"], ["f-location", "Localización"]]
          .forEach(([role, ph]) => {
            const el = $(role);
            if (el) { el.innerHTML = ph; el.classList.add("ph"); el.classList.remove("set"); }
          });
        const btn = $("btn"); if (btn) btn.classList.remove("press");
        show("toast", false);
        const bp = $("btn-pausa"); if (bp) bp.classList.remove("press");
        show("toast-pausa", false);
        show("scr-pausa", false);
        show("scr-fich", true);
      } else if (variant === "informes") {
        show("kpi", false); show("minis", false); show("team", false);
        const c = $("chart"); if (c) c.classList.remove("on");
        show("scr-hours", false);
        show("scr-list", true);
        show("fc-1", false); show("fc-2", false);
        text("subtitle", "Fichajes en curso");
      }
    }

    let acc = 0, last: number | null = null, idx = 0, rafId = 0;
    function frame(t: number) {
      if (last == null) last = t;
      const dt = Math.min(t - last, 100);
      last = t; acc += dt;
      while (idx < steps.length && acc >= steps[idx][0]) { steps[idx][1](); idx++; }
      if (acc >= loop) { acc = 0; idx = 0; domReset(); }
      rafId = requestAnimationFrame(frame);
    }
    function play() {
      if (running || reduce) return;
      running = true; last = null;
      rafId = requestAnimationFrame(frame);
    }
    function stop() {
      running = false;
      if (rafId) cancelAnimationFrame(rafId);
    }

    if (reduce) {
      steps.forEach(([, fn]) => fn());
      return;
    }

    if ("IntersectionObserver" in window) {
      const io = new IntersectionObserver(
        (entries) => (entries[0].isIntersecting ? play() : stop()),
        { threshold: 0.3 }
      );
      io.observe(scene);
    } else {
      play();
    }
  }

  document.querySelectorAll(".pmk-scene").forEach(initScene);
</script>
