---
import BrandLockup from "./BrandLockup.astro";

const { sticky = false } = Astro.props;

const headerClass = sticky
  ? "sticky top-0 z-50 w-full backdrop-blur-md bg-slate-50/70 border-b border-slate-200/50"
  : "border-b border-slate-200/70 bg-white/80 backdrop-blur";
---

<header class={headerClass}>
  <div class="container mx-auto px-6 py-4 max-w-6xl flex items-center justify-between">
    <BrandLockup textClass="text-brand-dark" />
    <div class="flex items-center gap-4">
      <slot name="actions" />
    </div>
  </div>
</header>
