---
// Footer con datos legales, contacto y copyright.
import BrandLockup from "./BrandLockup.astro";
---

<footer class="bg-brand-dark text-white/90 py-12">
    <div class="container mx-auto px-6 max-w-6xl">
        <div
            class="flex flex-col md:flex-row justify-between items-center gap-8"
        >
            <!-- Logo & Copyright -->
            <div class="text-center md:text-left">
                <BrandLockup
                    href="/"
                    invert={true}
                    imgClass="h-8"
                    textClass="text-white"
                    className="justify-center md:justify-start"
                />
                <p class="text-sm">Copyright &copy; 2026 Rapidgest</p>
            </div>

            <!-- Legal Links -->
            <nav class="flex flex-wrap justify-center gap-6 text-sm">
                <a
                    href="/politica-privacidad"
                    class="hover:text-white transition-colors"
                    >Política de privacidad</a
                >
                <a
                    href="/cookies"
                    class="hover:text-white transition-colors">Cookies</a
                >
                <a
                    href="/aviso-legal"
                    class="hover:text-white transition-colors">Aviso legal</a
                >
            </nav>

            <!-- Contact -->
            <div class="flex flex-col items-center md:items-end gap-1 text-sm">
                <a
                    href="tel:+34639060774"
                    class="hover:text-white transition-colors flex items-center gap-2"
                >
                    <svg
                        class="w-4 h-4"
                        fill="none"
                        stroke="currentColor"
                        viewBox="0 0 24 24"
                        ><path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="2"
                            d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"
                        ></path></svg
                    >
                    +34 639 06 07 74
                </a>
                <a
                    href="mailto:info@softtalia.com"
                    class="hover:text-white transition-colors flex items-center gap-2"
                >
                    <svg
                        class="w-4 h-4"
                        fill="none"
                        stroke="currentColor"
                        viewBox="0 0 24 24"
                        ><path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="2"
                            d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
                        ></path></svg
                    >
                    info@softtalia.com
                </a>
            </div>
        </div>
    </div>
</footer>
