---
// Un formulario limpio, pidiendo solo lo esencial para que convierta mejor.
const appsScriptUrl = import.meta.env.PUBLIC_APPS_SCRIPT_URL;
---

<section id="demo" class="py-20 bg-slate-50 relative">
  <div
    class="absolute top-0 inset-x-0 h-px bg-gradient-to-r from-transparent via-brand-light to-transparent"
  >
  </div>

  <div class="container mx-auto px-6 max-w-4xl">
    <div
      class="bg-white rounded-3xl shadow-xl shadow-brand-dark/5 border border-brand-light/50 overflow-hidden flex flex-col md:flex-row"
    >
      <div
        class="bg-brand-blue p-10 md:w-5/12 text-white flex flex-col justify-center relative overflow-hidden"
      >
        <div
          class="absolute -top-10 -right-10 w-40 h-40 bg-brand-green/20 rounded-full blur-2xl"
        >
        </div>

        <h3 class="text-3xl font-bold mb-4 relative z-10">
          Solicita tu demostración gratuita
        </h3>
        <p class="text-white/80 mb-6 relative z-10">
          Déjanos tus datos y un especialista de Rapidgest te enseñará la
          plataforma en menos de 24 horas.
        </p>
        <ul class="space-y-3 relative z-10">
          <li class="flex items-center gap-2 text-white/90">
            <svg
              class="w-5 h-5 text-brand-green"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
              ><path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M5 13l4 4L19 7"></path></svg
            >
            Sin compromiso
          </li>
          <li class="flex items-center gap-2 text-white/90">
            <svg
              class="w-5 h-5 text-brand-green"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
              ><path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M5 13l4 4L19 7"></path></svg
            >
            Configuración guiada
          </li>
        </ul>
      </div>

      <div class="p-10 md:w-7/12">
        <form id="lead-form" class="space-y-5" data-script-url={appsScriptUrl}>
          <div class="grid grid-cols-2 gap-5">
            <div>
              <label class="block text-sm font-medium text-brand-dark mb-1"
                >Nombre</label
              >
              <input
                type="text"
                name="nombre"
                class="w-full px-4 py-2.5 rounded-lg border border-brand-light focus:ring-2 focus:ring-brand-blue focus:border-brand-blue outline-none transition-all"
                placeholder="Tu nombre"
                required
              />
            </div>
            <div>
              <label class="block text-sm font-medium text-brand-dark mb-1"
                >Empresa</label
              >
              <input
                type="text"
                name="empresa"
                class="w-full px-4 py-2.5 rounded-lg border border-brand-light focus:ring-2 focus:ring-brand-blue focus:border-brand-blue outline-none transition-all"
                placeholder="Nombre empresa"
                required
              />
            </div>
          </div>
          <div>
            <label class="block text-sm font-medium text-brand-dark mb-1"
              >Email profesional</label
            >
            <input
              type="email"
              name="email"
              class="w-full px-4 py-2.5 rounded-lg border border-brand-light focus:ring-2 focus:ring-brand-blue focus:border-brand-blue outline-none transition-all"
              placeholder="hola@empresa.com"
              required
            />
          </div>
          <div>
            <label class="block text-sm font-medium text-brand-dark mb-1"
              >Telefono</label
            >
            <input
              type="tel"
              name="telefono"
              class="w-full px-4 py-2.5 rounded-lg border border-brand-light focus:ring-2 focus:ring-brand-blue focus:border-brand-blue outline-none transition-all"
              placeholder="600 000 000"
              required
            />
          </div>
          <input id="lead-interes" type="hidden" name="interes" value="fichaje" />
          <button
            id="demo-submit-btn"
            type="submit"
            disabled
            class="w-full bg-brand-blue hover:bg-brand-blue-hover text-white font-semibold py-3 px-6 rounded-lg transition-colors duration-200 mt-2 disabled:opacity-50 disabled:cursor-not-allowed"
          >
            Solicitar Demo Ahora
          </button>
          <p id="lead-form-status" class="hidden text-sm rounded-lg px-3 py-2"></p>
          <label class="flex items-start gap-2 mt-4 cursor-pointer">
            <input
              id="accept-privacy"
              type="checkbox"
              class="mt-0.5 w-4 h-4 rounded border-brand-light text-brand-blue focus:ring-brand-blue cursor-pointer"
            />
            <span class="text-xs text-brand-dark/50"
              >He leído y acepto la <a
                href="/politica-privacidad"
                class="underline hover:text-brand-blue transition-colors"
                >política de privacidad</a
              >.</span
            >
          </label>
        </form>
      </div>
    </div>
  </div>
</section>

<script>
  const form = document.getElementById("lead-form");
  const checkbox = document.getElementById("accept-privacy");
  const submitBtn = document.getElementById("demo-submit-btn");
  const interesInput = document.getElementById("lead-interes");
  const statusEl = document.getElementById("lead-form-status");

  const showStatus = (type, text) => {
    if (!statusEl) return;
    statusEl.textContent = text;
    statusEl.classList.remove(
      "hidden",
      "text-red-700",
      "bg-red-50",
      "border",
      "border-red-200",
      "text-emerald-700",
      "bg-emerald-50",
      "border-emerald-200"
    );

    if (type === "error") {
      statusEl.classList.add("text-red-700", "bg-red-50", "border", "border-red-200");
      return;
    }

    statusEl.classList.add("text-emerald-700", "bg-emerald-50", "border", "border-emerald-200");
  };

  const setInteres = (value) => {
    if (!value) return;
    sessionStorage.setItem("lead_interes", value);
    if (interesInput) interesInput.value = value;
  };

  document.querySelectorAll("[data-lead-interes]").forEach((el) => {
    el.addEventListener("click", () => {
      setInteres(el.getAttribute("data-lead-interes"));
    });
  });

  const urlParams = new URLSearchParams(window.location.search);
  const interesFromUrl = urlParams.get("interes");
  const interesFromSession = sessionStorage.getItem("lead_interes");
  setInteres(interesFromUrl || interesFromSession || "fichaje");

  checkbox?.addEventListener("change", () => {
    submitBtn.disabled = !checkbox.checked;
  });

  form?.addEventListener("submit", async (e) => {
    e.preventDefault();
    if (statusEl) statusEl.classList.add("hidden");

    if (!checkbox?.checked) {
      showStatus("error", "Debes aceptar la política de privacidad para continuar.");
      return;
    }

    const originalBtnText = submitBtn.textContent;
    submitBtn.textContent = "Enviando...";
    submitBtn.disabled = true;

    const formData = new FormData(form);
    const scriptURL = form.dataset.scriptUrl;

    if (!scriptURL || scriptURL === "TU_URL_DE_APPS_SCRIPT_AQUI") {
      showStatus("error", "Falta configurar la URL de Google Apps Script.");
      submitBtn.textContent = originalBtnText;
      submitBtn.disabled = !checkbox.checked;
      return;
    }

    try {
      await fetch(scriptURL, {
        method: "POST",
        body: formData,
        mode: "no-cors",
      });

      showStatus("success", "Formulario enviado. Gracias, te contactaremos pronto.");
      form.reset();
      setInteres("fichaje");
      submitBtn.disabled = true;
      checkbox.checked = false;
    } catch (error) {
      console.error("Error enviando formulario:", error);
      showStatus("error", "Hubo un error al enviar. Por favor, inténtalo de nuevo.");
      submitBtn.disabled = !checkbox.checked;
    } finally {
      submitBtn.textContent = originalBtnText;
    }
  });
</script>
