---
import '../styles/global.css';

// Importamos nuestros nuevos componentes de la carpeta components/
import LeadForm from '../components/LeadForm.astro';
import Features from '../components/Features.astro';

const heroData = {
  title: "Controla el horario de tu equipo sin complicaciones",
  subtitle: "La solución de fichaje digital integrada en Rapidgest. Registra jornadas, gestiona ausencias y cumple la normativa desde cualquier dispositivo en segundos.",
  ctaText: "Solicitar demo",
  ctaLink: "#demo", 
  appName: "Rapidgest"
};
---

<html lang="es" class="scroll-smooth">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <title>{heroData.appName} | Control Horario</title>
  </head>
  <body class="bg-white text-brand-dark font-sans antialiased">
    
    <header class="container mx-auto px-6 py-4 flex justify-between items-center">
      <div class="font-bold text-2xl text-brand-blue tracking-tight">
        {heroData.appName}<span class="text-brand-green">.</span>
      </div>
    </header>

    <main>
      <section class="container mx-auto px-6 pt-20 pb-16 text-center md:pt-32 md:pb-24">
        <div class="inline-block py-1 px-4 rounded-full bg-brand-blue/10 text-brand-blue text-sm font-bold mb-6 border border-brand-blue/20">
          Nuevo módulo de control horario
        </div>
        <h1 class="text-5xl md:text-6xl font-extrabold tracking-tight text-brand-dark mb-6 max-w-4xl mx-auto leading-tight">
          {heroData.title}
        </h1>
        <p class="text-lg md:text-xl text-brand-dark/80 mb-10 max-w-2xl mx-auto leading-relaxed">
          {heroData.subtitle}
        </p>
        <div class="flex justify-center gap-4">
          <a href={heroData.ctaLink} class="bg-brand-blue hover:bg-brand-blue-hover text-white font-semibold py-3 px-8 rounded-lg shadow-lg shadow-brand-blue/30 transition-all duration-200 transform hover:-translate-y-1">
            {heroData.ctaText}
          </a>
        </div>

        <div class="mt-16 max-w-5xl mx-auto bg-white rounded-2xl shadow-2xl border border-brand-light overflow-hidden aspect-video flex items-center justify-center bg-slate-50 relative group">
             <div class="absolute inset-0 bg-gradient-to-tr from-brand-blue/5 to-brand-green/5"></div>
             <p class="text-brand-dark/50 font-medium z-10">[ Aquí irá la imagen o captura de pantalla de la app Rapidgest ]</p>
        </div>
      </section>

      <LeadForm />

      <Features />
      
    </main>

  </body>
</html>