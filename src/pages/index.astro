---
// src/pages/index.astro
import "../styles/global.css";

import LeadForm from "../components/LeadForm.astro";
import Features from "../components/Features.astro";
import SocialProof from "../components/SocialProof.astro";
import StickyScroll from "../components/StickyScroll.astro";
import InteractiveDemo from "../components/InteractiveDemo.astro";
import Footer from "../components/Footer.astro";
import FAQ from "../components/FAQ.astro";
import ERPBanner from "../components/RapidgestBanner.astro";
import APISection from "../components/APISection.astro";

const heroData = {
  title: "Fichaje gratis para tu equipo",
  titleHighlight: "sin complicaciones",
  subtitle:
    "Controla el horario de tus empleados gratis con Rapidgest. Registro de jornada digital, gestión de ausencias y cumplimiento normativo desde cualquier dispositivo. Sin coste, sin compromiso.",
  ctaText: "Empezar gratis",
  ctaLink: "#demo",
  appName: "Rapidgest",
};
---

<html lang="es" class="scroll-smooth">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Primary SEO -->
    <title>Fichaje Gratis | Control Horario Digital Gratuito - Rapidgest</title>
    <meta
      name="description"
      content="Fichaje gratis para tu empresa. Controla el horario de tu equipo sin complicaciones con Rapidgest. Registro de jornada digital, gestión de ausencias y cumplimiento normativo desde cualquier dispositivo. 100% gratis."
    />
    <meta
      name="keywords"
      content="fichaje gratis, control horario gratis, fichaje digital, registro jornada laboral, control horario empleados, fichaje empleados gratis, rapidgest, app fichaje, control horario digital, registro horario gratis, fichaje online, gestión horaria, cumplimiento normativo fichaje"
    />
    <meta name="author" content="Rapidgest - Softtalia" />
    <meta
      name="robots"
      content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1"
    />
    <link rel="canonical" href="https://fichaje.rapidgest.com/" />

    <!-- Open Graph / Facebook / WhatsApp / LinkedIn -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://fichaje.rapidgest.com/" />
    <meta
      property="og:title"
      content="Fichaje Gratis | Control Horario Digital sin Coste - Rapidgest"
    />
    <meta
      property="og:description"
      content="La solución de fichaje digital gratuita de Rapidgest. Registra jornadas, gestiona ausencias y cumple la normativa laboral desde cualquier dispositivo en segundos."
    />
    <meta
      property="og:image"
      content="https://fichaje.rapidgest.com/logo-rapidges-001.png"
    />
    <meta property="og:image:alt" content="Rapidgest - Fichaje Gratis" />
    <meta property="og:site_name" content="Rapidgest Fichaje Gratis" />
    <meta property="og:locale" content="es_ES" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content="https://fichaje.rapidgest.com/" />
    <meta
      name="twitter:title"
      content="Fichaje Gratis | Control Horario Digital - Rapidgest"
    />
    <meta
      name="twitter:description"
      content="Controla el horario de tu equipo gratis. Registro de jornada digital, gestión de ausencias y cumplimiento normativo desde cualquier dispositivo."
    />
    <meta
      name="twitter:image"
      content="https://fichaje.rapidgest.com/logo-rapidges-001.png"
    />

    <!-- Additional SEO -->
    <meta name="theme-color" content="#109a9d" />
    <meta name="format-detection" content="telephone=no" />
    <link rel="sitemap" href="/sitemap.xml" />

    <!-- Structured Data / JSON-LD -->
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "SoftwareApplication",
        "name": "Rapidgest Fichaje Gratis",
        "applicationCategory": "BusinessApplication",
        "operatingSystem": "Web, iOS, Android",
        "offers": {
          "@type": "Offer",
          "price": "0",
          "priceCurrency": "EUR",
          "description": "Fichaje gratis - Control horario digital sin coste"
        },
        "description": "Solución de fichaje digital gratuita para empresas. Control horario, registro de jornada y gestión de ausencias desde cualquier dispositivo.",
        "url": "https://fichaje.rapidgest.com/",
        "publisher": {
          "@type": "Organization",
          "name": "Rapidgest",
          "url": "https://rapidgest.com/",
          "logo": "https://fichaje.rapidgest.com/logo-rapidges-001.png",
          "contactPoint": {
            "@type": "ContactPoint",
            "telephone": "+34-639-06-07-74",
            "email": "info@softtalia.com",
            "contactType": "sales"
          }
        }
      }
    </script>
  </head>
  <body
    class="bg-slate-50 text-brand-dark font-sans antialiased overflow-x-hidden relative"
  >
    <div
      class="absolute inset-0 z-[-2] h-screen w-full bg-[linear-gradient(to_right,#80808012_1px,transparent_1px),linear-gradient(to_bottom,#80808012_1px,transparent_1px)] bg-[size:24px_24px]"
    >
    </div>

    <div
      class="absolute top-0 right-0 -z-10 transform-gpu overflow-hidden blur-3xl opacity-30"
      aria-hidden="true"
    >
      <div
        class="aspect-[1108/632] w-[69.25rem] bg-gradient-to-r from-brand-blue to-brand-green"
        style="clip-path: polygon(73.6% 51.7%, 91.7% 11.8%, 100% 46.4%, 97.4% 82.2%, 92.5% 84.9%, 75.7% 64%, 55.3% 47.5%, 46.5% 49.4%, 45% 62.9%, 50.3% 87.2%, 21.3% 64.1%, 0.1% 100%, 5.4% 51.1%, 21.4% 63.9%, 58.9% 0.2%, 73.6% 51.7%)"
      >
      </div>
    </div>
    <div
      class="absolute -top-24 -left-40 -z-10 transform-gpu overflow-hidden blur-3xl opacity-20"
      aria-hidden="true"
    >
      <div class="aspect-[1108/632] w-[40rem] bg-brand-blue rounded-full"></div>
    </div>

    <header
      class="sticky top-0 z-50 w-full backdrop-blur-md bg-slate-50/70 border-b border-slate-200/50"
    >
      <div
        class="container mx-auto px-6 py-4 flex justify-between items-center"
      >
        <a href="#"
          ><img src="/logo-rapidges-001.png" alt="Rapidgest" class="h-10" /></a
        >
        <a
          href="#demo"
          class="bg-brand-blue hover:bg-brand-blue-hover text-white text-sm font-semibold py-2 px-5 rounded-lg transition-colors duration-200"
          >Solicitar demo</a
        >
      </div>
    </header>

    <main>
      <section
        class="container mx-auto px-6 pt-24 pb-16 text-center md:pt-36 md:pb-24 relative"
      >
        <h1
          class="text-5xl md:text-7xl font-extrabold tracking-tighter text-slate-900 mb-6 max-w-5xl mx-auto leading-[1.1]"
        >
          {heroData.title}
          <br class="hidden md:block" />
          <span
            class="text-transparent bg-clip-text bg-gradient-to-r from-brand-blue to-brand-blue-hover"
          >
            {heroData.titleHighlight}
          </span>
        </h1>

        <p
          class="text-lg md:text-xl text-slate-600 mb-10 max-w-2xl mx-auto leading-relaxed font-medium"
        >
          {heroData.subtitle}
        </p>

        <div class="flex flex-col sm:flex-row justify-center gap-4 mt-8">
          <a
            href={heroData.ctaLink}
            class="group relative inline-flex items-center justify-center gap-2 bg-brand-dark hover:bg-slate-800 text-white font-semibold py-3.5 px-8 rounded-xl transition-all duration-200 shadow-[0_1px_2px_rgba(0,0,0,0.1),0_8px_16px_rgba(0,0,0,0.1)] hover:-translate-y-0.5"
          >
            {heroData.ctaText}
            <svg
              class="w-4 h-4 transition-transform group-hover:translate-x-1"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
              ><path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg
            >
          </a>
          <a
            href="#como-funciona"
            class="inline-flex items-center justify-center gap-2 bg-white hover:bg-slate-50 text-brand-dark font-semibold py-3.5 px-8 rounded-xl transition-all duration-200 border border-slate-200 shadow-sm hover:border-slate-300"
          >
            Ver cómo funciona
          </a>
        </div>

        <div class="mt-20 max-w-6xl mx-auto relative group perspective-1000">
          <div
            class="absolute -inset-1 bg-gradient-to-r from-brand-blue to-brand-green rounded-[2rem] blur opacity-20 group-hover:opacity-30 transition duration-1000 group-hover:duration-200"
          >
          </div>

          <div
            class="relative bg-white rounded-3xl ring-1 ring-slate-200/50 shadow-2xl overflow-hidden aspect-[16/9] flex items-center justify-center transform transition-transform duration-500 hover:scale-[1.01]"
          >
            <div
              class="absolute top-0 w-full h-12 bg-slate-50/80 backdrop-blur-sm border-b border-slate-200 flex items-center px-4 gap-2 z-20"
            >
              <div class="w-3 h-3 rounded-full bg-slate-300"></div>
              <div class="w-3 h-3 rounded-full bg-slate-300"></div>
              <div class="w-3 h-3 rounded-full bg-slate-300"></div>
            </div>

            <div class="w-full h-full pt-12">
              <InteractiveDemo />
            </div>
          </div>
        </div>
      </section>

      <div class="relative z-10 bg-slate-50">
        <LeadForm />
        <SocialProof />
        <StickyScroll />
        <Features />
        <ERPBanner />
        <APISection />
        <FAQ />
      </div>
    </main>

    <Footer />
  </body>
</html>
